<div id="fab-group">
  <button class="fab" id="highlight-fab" title="Highlight entities">
    <span class="fab-icon">🔍</span>
    <span class="fab-label">Highlight</span>
  </button>
  <button class="fab" id="edit-btn" onclick="toggleEdit()" title="Edit document">
    <span class="fab-icon">✏️</span>
    <span class="fab-label">Edit</span>
  </button>
  <button class="fab" id="export-tts-btn" title="Export as audio">
    <span class="fab-icon">🔊</span>
    <span class="fab-label">Export</span>
  </button>
</div>