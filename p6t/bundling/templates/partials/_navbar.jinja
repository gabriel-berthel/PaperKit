<header id="navbar">
  <div class="nav-group">
    <button id="tts-prev-btn" title="Previous">⏮</button>
    <button id="tts-play-btn" title="Play">▶️</button>
    <button id="tts-pause-btn" title="Pause" style="display:none">⏸</button>
    <button id="tts-next-btn" title="Next">⏭</button>
    <span id="tts-label" class="tts-label">—</span>
    <label class="tts-auto">
      <input type="checkbox" id="tts-auto-toggle">
      Auto-advance
    </label>
  </div>
  <div class="nav-group">
    <button id="undo-btn" title="Undo">↶ Undo</button>
    <button id="redo-btn" title="Redo">↷ Redo</button>
    <div class="divider"></div>
    <button id="snapshot-btn">📷 Snapshot</button>
    <button id="snapshot-history-btn">History ▾</button>
  </div>
</header>